def read_merge_var(files, var, tgt_prof=None, resampling=Resampling.average):
    arr_all, dates_all = [], []
    prof_ref = None

    for fp in files:
        arr, dates, prof = read_stack_by_prefix(fp, var)
        if arr is None:
            continue

        if tgt_prof is not None:
            arr = reproject_stack_to_target(arr, prof, tgt_prof, resampling=resampling)

        arr_all.append(arr)
        dates_all.extend(dates)

        if prof_ref is None:
            prof_ref = prof

    if len(arr_all) == 0:
        return None, None, None

    arr_all = np.concatenate(arr_all, axis=0)
    dates_all = pd.to_datetime(pd.Series(dates_all)).dt.normalize().tolist()

    # sort
    order = np.argsort(pd.to_datetime(dates_all).values)
    arr_all = arr_all[order]
    dates_all = [dates_all[i] for i in order]

    # merge duplicate dates by mean
    df_idx = pd.DataFrame({"date": pd.to_datetime(dates_all), "idx": np.arange(len(dates_all))})
    grouped = df_idx.groupby("date")["idx"].apply(list)

    if grouped.apply(len).max() > 1:
        new_arr, new_dates = [], []
        for d, idxs in grouped.items():
            block = arr_all[idxs]
            new_arr.append(np.nanmean(block, axis=0).astype(np.float32))
            new_dates.append(pd.Timestamp(d).normalize())
        arr_all = np.stack(new_arr, axis=0)
        dates_all = new_dates

    return arr_all, dates_all, (tgt_prof if tgt_prof is not None else prof_ref)

def spatial_mean_ts(arr_THW):
    return np.nanmean(arr_THW.reshape(arr_THW.shape[0], -1), axis=1)

