# 5) ERA 8-day -> 16-day harmonization
# =========================
def aggregate_era8_to_era16(arr_8_THW, dates_8, var):
    """
    Convert ERA 8-day stacks to 16-day stacks using fixed anchors:
      2002-01-01, 2002-01-17, ...
    """
    dates_8 = pd.to_datetime(dates_8)
    start = pd.Timestamp("2002-01-01")
    end   = pd.Timestamp("2026-01-01")
    anchors = pd.date_range(start=start, end=end, freq="16D", inclusive="left")

    out_arrs, out_dates = [], []

    for a in anchors:
        b = a + pd.Timedelta(days=16)
        idx = np.where((dates_8 >= a) & (dates_8 < b))[0]

        if len(idx) == 0:
            continue

        block = arr_8_THW[idx]

        if var in MEAN_VARS:
            agg = np.nanmean(block, axis=0).astype(np.float32)
        elif var in SUM_VARS:
            agg = np.nansum(block, axis=0).astype(np.float32)
        else:
            agg = np.nanmean(block, axis=0).astype(np.float32)

        out_arrs.append(agg)
        out_dates.append(a.normalize())

    if len(out_arrs) == 0:
        return None, None

    out_arr = np.stack(out_arrs, axis=0)
    return out_arr, out_dates

