def build_city_pooled_rows(city):
    ERA_FILES, MERRA_FILES = discover_city_files(city)

    if len(ERA_FILES) == 0 or len(MERRA_FILES) == 0:
        return None

    # target grid from ERA T2M
    era_t2m, _, era_prof = read_merge_var(ERA_FILES, "T2M_C")
    if era_t2m is None:
        return None

    tgt_prof = make_target_profile_from_bounds(era_prof["bounds"], deg=TARGET_DEG)

    rows = []

    for var in CLIMATE_VARS:
        era_arr8, era_dates8, _ = read_merge_var(ERA_FILES, var, tgt_prof=tgt_prof, resampling=Resampling.average)
        mer_arr16, mer_dates16, _ = read_merge_var(MERRA_FILES, var, tgt_prof=tgt_prof, resampling=Resampling.average)

        if era_arr8 is None or mer_arr16 is None:
            continue

        era_arr16, era_dates16 = aggregate_era8_to_era16(era_arr8, era_dates8, var)
        if era_arr16 is None:
            continue

        era_ts = spatial_mean_ts(era_arr16)
        mer_ts = spatial_mean_ts(mer_arr16)

        s1 = pd.Series(era_ts, index=pd.to_datetime(era_dates16)).groupby(level=0).mean()
        s2 = pd.Series(mer_ts, index=pd.to_datetime(mer_dates16)).groupby(level=0).mean()

        df_cmp = pd.concat([s1.rename("ERA5"), s2.rename("MERRA")], axis=1).dropna()
        if len(df_cmp) == 0:
            continue

        df_cmp = df_cmp.reset_index().rename(columns={"index": "date"})
        df_cmp["city"] = city
        df_cmp["var"] = var
        rows.append(df_cmp)

    if len(rows) == 0:
        return None

    return pd.concat(rows, ignore_index=True)

